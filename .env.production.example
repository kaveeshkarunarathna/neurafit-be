# Production Environment Variables — copy to .env on your server
# WARNING: Fill in real secrets before deploying. Never commit this file.

NODE_ENV=production
PORT=3000

# Database
POSTGRES_USER=neurafit
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=neurafit
DATABASE_URL=postgresql://neurafit:CHANGE_ME_STRONG_PASSWORD@db:5432/neurafit

# Redis
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD
REDIS_URL=redis://:CHANGE_ME_REDIS_PASSWORD@redis:6379

# JWT
JWT_SECRET=CHANGE_ME_JWT_SECRET
JWT_REFRESH_SECRET=CHANGE_ME_JWT_REFRESH_SECRET
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS
FRONTEND_URL=https://your-app.vercel.app

# AI
GOOGLE_AI_API_KEY=your-google-ai-key
